+struct SearchControlRow: View {
+    @EnvironmentObject private var store: SaviStore
+    let resultCount: Int
+    let hasLiveSearch: Bool
+
+    var body: some View {
+        HStack(spacing: 8) {
+            Label(countTitle, systemImage: hasLiveSearch ? "line.3.horizontal.decrease.circle.fill" : "tray.full.fill")
+                .font(SaviType.ui(.caption, weight: .black))
+                .foregroundStyle(SaviTheme.metadataText)
+                .lineLimit(1)
+                .padding(.horizontal, 11)
+                .frame(height: 34)
+                .background(SaviTheme.subtleSurface.opacity(0.48))
+                .clipShape(Capsule())
+                .overlay(Capsule().stroke(SaviTheme.cardStroke.opacity(0.5), lineWidth: 1))
+                .accessibilityLabel("\(resultCount) \(hasLiveSearch ? "matching results" : "recent saves")")
+
+            Spacer(minLength: 8)
+
+            SearchRefineButton()
+
+            if store.hasActiveSearchControls {
+                Button {
+                    store.resetFilters()
+                } label: {
+                    Label("Clear", systemImage: "xmark.circle.fill")
+                        .labelStyle(.titleAndIcon)
+                        .font(SaviType.ui(.caption, weight: .black))
+                        .padding(.horizontal, 11)
+                        .frame(height: 36)
+                        .foregroundStyle(SaviTheme.accentText)
+                        .background(SaviTheme.surfaceRaised.opacity(0.88))
+                        .clipShape(Capsule())
+                        .overlay(Capsule().stroke(SaviTheme.cardStroke.opacity(0.72), lineWidth: 1))
+                }
+                .buttonStyle(SaviPressScaleButtonStyle())
+                .accessibilityLabel("Clear all search filters")
+                .transition(.opacity.combined(with: .scale(scale: 0.96)))
+            }
+        }
     }
+
+    private var countTitle: String {
+        if hasLiveSearch {
+            return "\(resultCount) result\(resultCount == 1 ? "" : "s")"
+        }
+        return "\(resultCount) saved"
+    }
 }

