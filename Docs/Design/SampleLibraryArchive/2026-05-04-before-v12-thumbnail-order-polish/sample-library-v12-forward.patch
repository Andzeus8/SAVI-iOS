+    private static func samplePhotoThumb(
+        imageName: String,
+        fallbackAccentHex: String,
+        overlay: @escaping (UIGraphicsImageRendererContext, CGRect) -> Void
+    ) -> String {
+        let size = CGSize(width: 720, height: 720)
+        let format = UIGraphicsImageRendererFormat()
+        format.scale = 2
+        format.opaque = true
+
+        let image = UIGraphicsImageRenderer(size: size, format: format).image { context in
+            let bounds = CGRect(origin: .zero, size: size)
+            if let source = UIImage(named: imageName) {
+                let imageSize = source.size
+                let scale = max(bounds.width / imageSize.width, bounds.height / imageSize.height)
+                let drawSize = CGSize(width: imageSize.width * scale, height: imageSize.height * scale)
+                let drawRect = CGRect(
+                    x: (bounds.width - drawSize.width) / 2,
+                    y: (bounds.height - drawSize.height) / 2,
+                    width: drawSize.width,
+                    height: drawSize.height
+                )
+                source.draw(in: drawRect)
+            } else {
+                let colors = [
+                    UIColor(hex: fallbackAccentHex).cgColor,
+                    UIColor(hex: "#2A1745").cgColor
+                ] as CFArray
+                if let gradient = CGGradient(colorsSpace: CGColorSpaceCreateDeviceRGB(), colors: colors, locations: [0, 1]) {
+                    context.cgContext.drawLinearGradient(
+                        gradient,
+                        start: CGPoint(x: 0, y: 0),
+                        end: CGPoint(x: bounds.maxX, y: bounds.maxY),
+                        options: []
+                    )
+                } else {
+                    UIColor(hex: fallbackAccentHex).setFill()
+                    context.fill(bounds)
+                }
+            }
+
+            overlay(context, bounds)
+        }
+
+        guard let data = image.jpegData(compressionQuality: 0.82) else {
+            return picsumThumb("savi-sample-\(imageName)", width: 720, height: 720)
+        }
+        return "data:image/jpeg;base64,\(data.base64EncodedString())"
+    }
+
+    private static func drawPhotoBottomShade(_ context: CGContext, bounds: CGRect, opacity: CGFloat = 0.58) {
+        let colors = [
+            UIColor.black.withAlphaComponent(0.0).cgColor,
+            UIColor.black.withAlphaComponent(opacity).cgColor
+        ] as CFArray
+        if let gradient = CGGradient(colorsSpace: CGColorSpaceCreateDeviceRGB(), colors: colors, locations: [0.28, 1]) {
+            context.drawLinearGradient(
+                gradient,
+                start: CGPoint(x: bounds.midX, y: bounds.minY),
+                end: CGPoint(x: bounds.midX, y: bounds.maxY),
+                options: []
+            )
+        }
+    }
+
