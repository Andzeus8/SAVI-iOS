+    static func shouldReplaceAttachmentTitle(current: String, fileName: String?, candidate: String) -> Bool {
+        let normalized = current.trimmingCharacters(in: .whitespacesAndNewlines).lowercased()
+        let fileBase = (fileName ?? "")
